---
import "../villa-map/styles.css";
import VillaMap from "../villa-map/react/VillaMap.jsx";

const title = "猪猪山庄实景地图 | Cochonnet Villa";
const description = "Explore the expanded 3D villa grounds, hot springs, mushroom house, and main hall of Cochonnet Villa.";
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffe9d5" />
    <link rel="canonical" href="https://www.cochonnetvilla.ca/villa-map/" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="villa-map-page">
    <div class="villa-map-shell">
      <header class="villa-map-header">
        <a class="villa-map-brand" href="/">猪猪山庄实景地图</a>
        <a class="villa-map-back" href="/">返回主页</a>
      </header>

      <!-- 3D villa map runs as a client-only React Three Fiber island.
           Three.js needs `window`, so there is no SSR pass. -->
      <VillaMap client:only="react" />
    </div>
  </body>
</html>
