---
import "../villa-map/styles.css";

const title = "猪猪山庄实景地图 | Cochonnet Villa";
const description = "Explore the cozy 3D courtyard and great hall of Cochonnet Villa.";
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffe9d5" />
    <link rel="canonical" href="https://www.cochonnetvilla.ca/villa-map/" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="villa-map-page">
    <div class="villa-map-shell">
      <header class="villa-map-header">
        <a class="villa-map-brand" href="/">猪猪山庄实景地图</a>
        <a class="villa-map-back" href="/">返回主页</a>
      </header>

      <main class="villa-map-root" data-villa-map-root>
        <canvas class="villa-map-canvas" data-villa-canvas aria-label="猪猪山庄 3D 自由探索地图"></canvas>

        <section class="villa-map-overlay" aria-label="地图控制说明">
          <h1>进入猪猪山庄</h1>
          <p>第一版开放小院和大厅。点击开始后，使用键盘移动，鼠标环视，靠近小猪和牌子会出现故事卡片。</p>
          <div class="villa-map-controls" aria-label="键盘控制">
            <kbd>W</kbd>
            <kbd>A</kbd>
            <kbd>S</kbd>
            <kbd>D</kbd>
            <kbd>Mouse</kbd>
            <kbd>Esc</kbd>
          </div>
          <button class="villa-map-start" type="button" data-start-exploring>开始探索</button>
          <p class="villa-map-status" data-lock-status>点击开始后使用 WASD + 鼠标探索</p>
        </section>

        <div class="villa-map-loading" data-loading>正在搭建猪猪山庄...</div>

        <aside class="interaction-panel" data-interaction-panel hidden>
          <h2 data-interaction-title></h2>
          <p data-interaction-body></p>
        </aside>

        <p class="villa-map-mobile-note">当前版本桌面体验最佳。请在电脑上使用 WASD 和鼠标自由探索。</p>
      </main>
    </div>

    <script>
      import "../villa-map/index.js";
    </script>
  </body>
</html>
